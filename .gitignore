# 1. Ignore everything by default
*

# 2. Allow Git to traverse directories (critical, otherwise it won't check subfolders)
!*/
!**/

# 3. Un-ignore specific root files we need
!.gitignore
!requirements.txt
!Dockerfile

# 4. Un-ignore the Django folders and files
!campushub/
!campushub/manage.py
!campushub/campushub/
!campushub/campushub/**
!campushub/core/
!campushub/core/**

# 5. Re-ignore specific patterns inside the allowed folders
**/.env
**/__pycache__/
**/*.pyc
**/media/
**/*.sqlite3
